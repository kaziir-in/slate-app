# ─── ENVIRONMENT VARIABLES TEMPLATE ───────────────────────────────
# INSTRUCTIONS: Copy this file, rename it to '.env', and fill in your actual keys.
# SECURITY NOTE: The actual '.env' file is git-ignored. Never commit real credentials.

# ─── AI INFRASTRUCTURE (API SHARDING) ─────────────────────────────
# Architecture Note: We require three separate API keys to implement a 
# Round-Robin Load Balancer. This allows the app to process massive payloads 
# (like verifying a 50+ item cart) using concurrent requests without triggering 
# Google's strict 15 Requests-Per-Minute (HTTP 429) quota limits.
GEMINI_API_KEY=your_first_api_key_here
GEMINI_API_KEY_2=your_second_api_key_here
GEMINI_API_KEY_3=your_third_api_key_here

# ─── CLOUD DATABASE (RAILWAY POSTGRES) ────────────────────────────
# Architecture Note: This connects the Node.js backend to the persistent 
# cloud storage for cross-device list syncing.
# CRITICAL FIX: The '?sslmode=require' parameter at the end is mandatory. 
# Railway's infrastructure enforces strict encryption and will actively reject 
# the connection if this flag is missing.
DATABASE_URL=postgresql://postgres:UuvyGByekZRkCBUndzoJNfeOjIytNkLy@mainline.proxy.rlwy.net:56865/railway?sslmode=require

# ─── SERVER CONFIGURATION ─────────────────────────────────────────
PORT=3000